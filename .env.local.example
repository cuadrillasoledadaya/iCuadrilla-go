# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Master Administrator Email (REQUIRED)
# This email is the sole authority for master/superadmin access.
# If unset or empty, master checks fail closed (isMaster = false).
# No hardcoded fallback exists — you MUST set this for master access to work.
MASTER_EMAIL=

# API Secret Key
API_SECRET_KEY=
