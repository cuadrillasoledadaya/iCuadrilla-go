{
  "compilerOptions": {
    "types": ["jest", "node"],
    "module": "commonjs",
    "target": "es2020",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*"],
  "exclude": ["node_modules"]
}
